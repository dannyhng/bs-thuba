  .testimonial-card { padding: 1.5rem; }

  /* Appointment */
  .apt-wrap { grid-template-columns: 1fr; gap: 2rem; }
  .zalo-card { flex-direction: column; text-align: center; }

  /* Media strip */
  .media-strip-inner {
    justify-content: flex-start;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 0.5rem;
    -webkit-overflow-scrolling: touch;
