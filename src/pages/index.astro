    /* ── FLOATING BUTTONS ── */
    .fab-group {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 500;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-end;
    }
    .fab {
      width: 52px; height: 52px;
      border-radius: 50%;
